@project {
    name: "http"
    version: "1.0.0-beta"
    license: "MIT"
    entry: "src/main.hc"
}

@description {
    summary: "HTTP client and server library for hica"
    author: "Claes Adamsson"
    homepage: "https://www.hica.dev"
    repository: "https://github.com/cladam/http"
}

@koka {
    include: "./src"
    flags: "--cclib=curl --cclib=microhttpd --ccincdir=/opt/homebrew/include --cclinkopts=-L/opt/homebrew/lib"
}

@dependencies {
    json: "latest"
}
